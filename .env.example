# -- App ------------------------------------------
APP_ENV=development
SECRET_KEY=change_this_to_a_random_secret

# -- ASR ------------------------------------------
ASR_MODEL=faster-whisper
WHISPER_MODEL_SIZE=small.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# -- Circuit Breaker -------------------------------
ASR_CONFIDENCE_THRESHOLD=0.75
CIRCUIT_BREAKER_FAILURE_COUNT=3
CIRCUIT_BREAKER_COOLDOWN_SECONDS=60

# -- Cloud ASR Fallback (optional paid) ------------
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=

# -- Celery + RabbitMQ -----------------------------
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -- Redis -----------------------------------------
REDIS_URL=redis://localhost:6379/0

# -- Database --------------------------------------
DATABASE_URL=postgresql://sas_user:sas_pass@localhost:5432/sas_db

# -- Storage ---------------------------------------
UPLOAD_DIR=uploads
REPORTS_DIR=reports
MODELS_DIR=models
MAX_UPLOAD_DURATION_MINUTES=60

# -- Scoring ---------------------------------------
DEFAULT_ROLE=general
